# Keep this repository focused on Sentinel source and Agent Lab artifacts.
# Everything else in the local workspace is ignored by default.
*

!.gitignore
!README.md
!sentinel-control/
!sentinel-control/**
!agent-lab/
!agent-lab/**
!RedditPulse/
!RedditPulse/**
!PLAN/
!PLAN/**

# Secrets and environment files
**/.env
**/.env.*
!**/.env.example

# Dependency and build outputs
**/node_modules/
**/.next/
**/dist/
**/build/
**/.turbo/
**/*.tsbuildinfo

# Python local state
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.venv/
**/venv/

# Sentinel generated/local runtime state
sentinel-control/data/generated_projects/
sentinel-control/data/traces/
sentinel-control/data/evidence_cache/
sentinel-control/data/memory/
sentinel-control/data/mission_state.json
sentinel-control/data/web_state.json
sentinel-control/services/sentinel-core/data/generated_projects/
sentinel-control/services/sentinel-core/w/

# Agent Lab vendor source clones are research inputs, not repo-owned source.
agent-lab/vendors/*/source/

# RedditPulse local state and nested repository metadata
RedditPulse/.git/
RedditPulse/.gitnexus/
RedditPulse/.claude/
RedditPulse/AGENTS.md
RedditPulse/CLAUDE.md
RedditPulse/**/.env
RedditPulse/**/.env.*
!RedditPulse/**/.env.example
RedditPulse/**/node_modules/
RedditPulse/**/.next/
RedditPulse/**/__pycache__/
RedditPulse/**/.pytest_cache/
RedditPulse/**/.venv/
RedditPulse/**/dist/
RedditPulse/**/output/
RedditPulse/**/*.pyc
RedditPulse/engine/data/working_proxies.json
RedditPulse/engine/data/working_proxies.txt

# Logs and local reports
**/*.log
*.log

# Local benchmark scratch outputs. Keep benchmark source and reports tracked.
agent-lab/benchmarks/browser_tasks/tmp_*/
